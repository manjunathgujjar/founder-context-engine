# Copy to .env and fill in. The .env file is gitignored.

# Required for grounded answer synthesis.
OPENROUTER_API_KEY=

# Optional overrides.
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RETRIEVAL_TOP_K=8

# Pin TODAY to a fixed ISO date (e.g. 2026-06-12) for deterministic demo answers.
# Leave unset to use the real current date at request time.
PINNED_TODAY=
